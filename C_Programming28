#include <stdio.h>
int disp_lcm(int a, int b)
{
    int i;
    for(i = (a > b ? a : b); ; i++)
    {
        if(i % a == 0 && i % b == 0)
            return i;
    }
}
int main()
{
    int n1, n2;
    printf("Enter two numbers: ");
    scanf("%d%d", &n1, &n2);
    printf("LCM = %d", disp_lcm(n1, n2));
    return 0;
}
