#include <stdio.h>
int disp_two_digit_square(int n)
{
    int num, count = 0;
    while(n > 0)
    {
        num = n % 100;   // get last 2 digits
        if(num == 16 || num == 25 || num == 36 ||
           num == 49 || num == 64 || num == 81)
        {
            count++;
        }
        n = n / 10;
    }
    return count;
}
int main()
{
    int num;
    printf("Enter a number: ");
    scanf("%d", &num);
    printf("Total two digit perfect square numbers = %d",
           disp_two_digit_square(num));
    return 0;
}
