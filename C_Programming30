#include <stdio.h>
int disp_HCF(int a, int b)
{
    int i, hcf = 1;
    for(i = 1; i <= a && i <= b; i++)
    {
        if(a % i == 0 && b % i == 0)
            hcf = i;
    }
    return hcf;
}
int main()
{
    int n1, n2;
    printf("Enter two numbers: ");
    scanf("%d%d", &n1, &n2);
    printf("HCF = %d", disp_HCF(n1, n2));
    return 0;
}
