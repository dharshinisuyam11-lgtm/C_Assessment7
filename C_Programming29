#include <stdio.h>
int disp_lcm(int a, int b, int c)
{
    int i, max;
    max = a;
    if(b > max) max = b;
    if(c > max) max = c;
    for(i = max; ; i++)
    {
        if(i % a == 0 && i % b == 0 && i % c == 0)
            return i;
    }
}
int main()
{
    int n1, n2, n3;
    printf("Enter three numbers: ");
    scanf("%d%d%d", &n1, &n2, &n3);
    printf("LCM = %d", disp_lcm(n1, n2, n3));
    return 0;
}
