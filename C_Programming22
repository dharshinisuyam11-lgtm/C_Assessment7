#include <stdio.h>
int disp_total_2digit_odd(int n)
{
    int count = 0;
    while(n > 0)
    {
        int digit = n % 100;   // get last 2 digits
        if(digit >= 10 && digit <= 99 && digit % 2 != 0)
            count++;
        n = n / 10;
    }
    return count;
}
int main()
{
    int num;
    printf("Enter a number: ");
    scanf("%d", &num);
    printf("Total 2-digit odd numbers = %d", disp_total_2digit_odd(num));
    return 0;
}
