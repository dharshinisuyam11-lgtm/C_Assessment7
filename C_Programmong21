#include <stdio.h>
int disp_total_odd_digits(int n)
{
    int count = 0;
    while(n > 0)
    {
        if((n % 10) % 2 != 0)
            count++;
        n = n / 10;
    }
    return count;
}
int main()
{
    int num;
    printf("Enter a number: ");
    scanf("%d", &num);
    printf("Total odd digits = %d", disp_total_odd_digits(num));
    return 0;
}
