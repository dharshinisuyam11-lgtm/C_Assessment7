#include <stdio.h>
void check_prime(int n)
{
    int h, t;
    h = n / 100;
    t = (n / 10) % 10;
    if((h==2 || h==3 || h==5 || h==7) &&
       (t==2 || t==3 || t==5 || t==7))
        printf("Prime");
    else
        printf("Not Prime");
}
int main()
{
    int n;
    scanf("%d", &n);
    check_prime(n);
    return 0;
}
