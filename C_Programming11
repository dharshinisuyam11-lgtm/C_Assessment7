#include <stdio.h>
int count_total_digits(int n)
{
    int count = 0;
    while (n > 0)
    {
        count++;
        n = n / 10;
    }
    return count;
}
int main()
{
    int num;
    printf("Enter a number: ");
    scanf("%d", &num);
    printf("Total digits = %d", count_total_digits(num));
    return 0;
}
