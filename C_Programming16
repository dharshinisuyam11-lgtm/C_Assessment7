#include <stdio.h>
void check_prime(int n)
{
    int i, count = 0;
    for(i = 1; i <= n; i++)
    {
        if(n % i == 0)
        {
            count++;
        }
    }
    if(count == 2)
        printf("Prime Number");
    else
        printf("Not a Prime Number");
}
int main()
{
    int num;
    printf("Enter a number: ");
    scanf("%d", &num);
    check_prime(num);
    return 0;
}
